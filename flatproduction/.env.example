# Leave empty for local dev (uses Vite's dev proxy → VITE_BACKEND_PORT below).
# For production, set this to your backend's real origin so uploaded-image
# URLs ("/uploads/...") resolve there instead of against the frontend's own
# domain, e.g.:
#   VITE_API_URL=https://api.flatproduction.rw
VITE_API_URL=

# Dev-only: which local port the backend runs on, used by Vite's dev proxy.
VITE_BACKEND_PORT=8000
